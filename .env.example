# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Vercel Blob (auto-set on Vercel; for local dev copy from project settings)
BLOB_READ_WRITE_TOKEN=

# Inngest (dev mode works without keys via the local dev server; set for prod)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Vision + LLM (primary)
OPENAI_API_KEY=

# Vision/LLM fallback + image generation (primary): Gemini 2.5 Flash (Image)
GOOGLE_GENERATIVE_AI_API_KEY=

# Image generation fallback: Fal (FLUX.1 Kontext)
FAL_KEY=
